        "transcendencia",
        "contemplacao"
      ]
    },
    {
      "id": "q004",
      "quote_text": "Dá-me castidade e continência, mas não agora.",
      "quote_text_original": "Da mihi castitatem et continentiam, sed noli modo.",
      "author": "Santo Agostinho",
      "work_title": "Confessiones",
      "reference": "VIII, 7, 17",
      "translation_note": "Tradução própria (literal).",
      "confidence_level": "alta",
      "source_url": "https://www.thelatinlibrary.com/augustine/conf8.shtml",
      "suggested_display_text": "Mas não agora.",

        "juventude"
      ]
    },
    {
      "id": "q003",
      "quote_text": "Tu, porém, eras mais íntimo que o meu íntimo e mais alto que o meu cume.",
      "quote_text_original": "Tu autem eras interior intimo meo et superior summo meo.",
      "author": "Santo Agostinho",
      "work_title": "Confessiones",
      "reference": "III, 6, 11",
      "translation_note": "Tradução própria (quase literal).",
      "confidence_level": "alta",
      "source_url": "https://www.thelatinlibrary.com/augustine/conf3.shtml",
      "suggested_display_text": "Mais íntimo que o meu íntimo…",
      "tags": [

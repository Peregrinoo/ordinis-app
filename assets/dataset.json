        "oracao",
        "interioridade"
      ]
    },
    {
      "id": "q002",
      "quote_text": "Eu ainda não amava, mas já amava o próprio amar.",
      "quote_text_original": "Nondum amabam, et amare amabam.",
      "author": "Santo Agostinho",
      "work_title": "Confessiones",
      "reference": "III, 1, 1",
      "translation_note": "Tradução própria (adaptada para fluência em pt-BR).",
      "confidence_level": "alta",
      "source_url": "https://www.thelatinlibrary.com/augustine/conf3.shtml",
      "suggested_display_text": "Amava o próprio amar.",
      "tags": [

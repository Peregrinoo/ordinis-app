      "author": "Santo Agostinho",
      "work_title": "Confessiones",
      "reference": "I, 1, 1",
      "translation_note": "Tradução própria (mais literal), a partir do latim.",
      "confidence_level": "alta",
      "source_url": "https://www.thelatinlibrary.com/augustine/conf1.shtml",
      "suggested_display_text": "Inquieto está o nosso coração…",
      "tags": [
        "busca",
